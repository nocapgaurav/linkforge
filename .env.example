PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://linkforge:linkforge@localhost:5432/linkforge?schema=public
PUBLIC_BASE_URL=http://localhost:3000
# Optional — leave unset to run without Redis (no-op cache, v1 behavior).
REDIS_URL=redis://localhost:6379
# Opt-in — anything but "true" disables click recording (no-op sink).
ANALYTICS_ENABLED=true
# Optional — browser origin allowed to call the API (CORS). Unset = no CORS.
FRONTEND_ORIGIN=http://localhost:3001
